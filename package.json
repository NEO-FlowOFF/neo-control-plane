{
  "name": "neoflowoff-tiktok-platform",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm --recursive run build",
    "check": "pnpm --filter @neomello/db run build && pnpm --filter @neomello/tiktok-sdk run build && pnpm --recursive run check",
    "db:generate": "pnpm --filter @neomello/db run db:generate",
    "db:validate": "pnpm --filter @neomello/db run db:validate"
  }
}