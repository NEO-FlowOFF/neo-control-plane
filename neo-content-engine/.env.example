# Copie este arquivo para `.env` na raiz do modulo e ajuste os valores reais.

# Chaves de IA e pesquisa
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...
OPENAI_MODEL=gpt-4o-mini

# TikTok Shop API para mineracao real de catalogo afiliado
# O engine aceita os nomes canonicos do workspace e tambem aliases legacy.
TIKTOK_ACCESS_TOKEN=
TIKTOK_SHOP_APP_KEY=
TIKTOK_SHOP_APP_SECRET=
TIKTOK_SHOP_CIPHER=
TIKTOK_SHOP_API_BASE_URL=https://open-api.tiktokglobalshop.com

# Aliases legacy aceitos pelo engine, mas nao recomendados como fonte principal.
# TIKTOK_APP_KEY=
# TIKTOK_CLIENT_SECRET=

# Geracao de imagem fallback quando o CSV nao traz `image_url`
NEO_GENERATE_IMAGE_IF_MISSING=1
OPENAI_IMAGE_MODEL=gpt-image-1
NEO_IMAGE_SIZE=1024x1536
NEO_IMAGE_QUALITY=low

# Limites operacionais
NEO_MINE_MAX_RESULTS_PER_QUERY=15
NEO_MINE_LIMIT_PRODUCTS=20
NEO_RUN_MAX_PRODUCTS=10
NEO_RUN_SLEEP_BETWEEN_PRODUCTS=3

# Upload e object storage
# Privado por padrao. Defina `NEO_MINIO_PUBLIC_READ=1` apenas se quiser URLs publicas.
NEO_MINIO_PUBLIC_READ=0
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_BASE_URL=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=tiktok-assets
